PORT=3001

# Use localhost:5432 for access from your host machine (e.g. Prisma migrations)
# If you encounter a port conflict, change this to localhost:5433 and update root .env
# Inside Docker, this is automatically overridden by the service name 'db' via docker-compose.yml
# You can find these credentials in the root .env or .env.example file.
# Do not replace the localhost value (only the localhost) so that you can run the command while in the server directory.
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME?schema=public

ACCESS_TOKEN_SECRET=your-super-secret-access-token-key
ACCESS_TOKEN_DURATION=15m

REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_DURATION=7d

FRONTEND_URL=http://localhost:5173

RESEND_API_KEY=your-resend-api-key

NODE_ENV=development


# Check the root .env config
# POSTGRES_USER=your_db_user
# POSTGRES_PASSWORD=your_db_password
# POSTGRES_DB=boilerplate_db
# POSTGRES_PORT=5432
# POSTGRES_HOST=db
