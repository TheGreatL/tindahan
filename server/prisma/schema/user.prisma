model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  firstName    String
  lastName     String
  avatar       String?       @default("test")
  session      Session[]
  lastLogin    DateTime?
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt()
  deletedAt    DateTime?
  activityLogs ActivityLog[]

  @@index([roleId])
  @@map("users")
}

