enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

model ActivityLog {
  id         String         @id @default(uuid())
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     ActivityAction
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime       @default(now())

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("activity_logs")
}
